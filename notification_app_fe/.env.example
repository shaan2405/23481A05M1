## Frontend config (Vite)
## Copy this file to `.env.local` and fill values.

# Notifications API base
VITE_API_BASE_URL=http://4.224.186.213/evaluation-service
VITE_API_TOKEN=

# Optional: auth payload to auto-mint short-lived token
VITE_AUTH_EMAIL=
VITE_AUTH_NAME=
VITE_AUTH_ROLL_NO=
VITE_AUTH_ACCESS_CODE=
VITE_AUTH_CLIENT_ID=
VITE_AUTH_CLIENT_SECRET=

# Optional: remote logging (leave empty to disable auth header)
VITE_LOG_ENDPOINT=http://4.224.186.213/evaluation-service/logs
VITE_LOG_TOKEN=

